# Ipmort libraries
import boto3
from PIL import Image, ImageDraw
import matplotlib.pyplot as plt
import os

#Configure S3
# Replace with your actual S3 bucket name
bucket_name = 'smile-detection-lab-yourname'
object_key = 'webcam_20260315_022647.jpg'  # Example key, update with your uploaded image
local_image = 'webcam_20260315_022647.jpg'

# Initialize S3 client
s3 = boto3.client('s3')

# Download image from S3
s3.download_file(bucket_name, object_key, local_image)
print(f"Image downloaded from S3: {local_image}")

#Display image
# Show the downloaded image
img = Image.open(local_image)
plt.figure(figsize=(6, 4))
plt.imshow(img)
plt.axis('off')
plt.title("Captured Webcam Image")
plt.show()

## Show the downloaded image
img = Image.open(local_image)
plt.figure(figsize=(6, 4))
plt.imshow(img)
plt.axis('off')
plt.title("Captured Webcam Image")
plt.show()

#Detect Faces & Smiles Using Rekognition
# Initialize Rekognition client
rekognition = boto3.client("rekognition")

# Read image bytes
with open(local_image, "rb") as image_file:
    image_bytes = image_file.read()

# Detect faces and attributes
response = rekognition.detect_faces(Image={"Bytes": image_bytes}, Attributes=["ALL"])

# Print smile and emotions info
for i, faceDetail in enumerate(response["FaceDetails"], start=1):
    smile = faceDetail["Smile"]
    print(f"Face {i}:")
    print(f"  Smile: {smile['Value']} (Confidence: {smile['Confidence']:.2f}%)")
    print("  Emotions:")
    for emotion in faceDetail["Emotions"]:
        print(f"    {emotion['Type']}: {emotion['Confidence']:.2f}%")
    print("-" * 30)

## Initialize Rekognition client
rekognition = boto3.client("rekognition")

# Read image bytes
with open(local_image, "rb") as image_file:
    image_bytes = image_file.read()

# Detect faces and attributes
response = rekognition.detect_faces(Image={"Bytes": image_bytes}, Attributes=["ALL"])

# Print smile and emotions info
for i, faceDetail in enumerate(response["FaceDetails"], start=1):
    smile = faceDetail["Smile"]
    print(f"Face {i}:")
    print(f"  Smile: {smile['Value']} (Confidence: {smile['Confidence']:.2f}%)")
    print("  Emotions:")
    for emotion in faceDetail["Emotions"]:
        print(f"    {emotion['Type']}: {emotion['Confidence']:.2f}%")
    print("-" * 30)

#Annotate Image with Bounding Boxes
# Draw bounding boxes around detected faces
image = Image.open(local_image)
img_width, img_height = image.size
draw = ImageDraw.Draw(image)

for i, face in enumerate(response['FaceDetails'], start=1):
    smile = face['Smile']
    status = 'Smiling' if smile['Value'] else 'Not Smiling'
    confidence = smile['Confidence']

    box = face['BoundingBox']
    left = img_width * box['Left']
    top = img_height * box['Top']
    width = img_width * box['Width']
    height = img_height * box['Height']

    # Draw rectangle
    draw.rectangle([left, top, left + width, top + height], outline='red', width=3)
    # Add text
    draw.text((left, top + height + 5), f"{status} ({confidence:.1f}%)", fill='green')

plt.figure(figsize=(10, 6))
plt.imshow(image)
plt.axis('off')
plt.title("Smile Detection Output")
plt.show()